# Neon pooled connection string (recommended for app runtime)
DATABASE_URL="postgresql://<user>:<password>@<your-neon-host>/<db>?sslmode=require&channel_binding=require"

# Neon direct connection string (recommended for Prisma migrations)
DIRECT_URL="postgresql://<user>:<password>@<your-neon-host>/<db>?sslmode=require&channel_binding=require"

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="google-client-id"
AUTH_GOOGLE_SECRET="google-client-secret"
